<?php
include('includes/config.php');

if (!isset($_GET['uid']) || !isset($_GET['dt'])) {
    die("Invalid request.");
}

$uid = intval($_GET['uid']);
$orderTime = $_GET['dt']; // exact datetime string

// Fetch orders with exact timestamp match for that user
$query = mysqli_query($con, "
    SELECT o.*, u.name, u.email, u.shippingAddress, u.shippingCity, u.shippingState, u.shippingPincode,
           p.productName, p.productPrice, p.productCompany
    FROM orders o
    JOIN users u ON o.userId = u.id
    JOIN products p ON o.productId = p.id
    WHERE o.userId = $uid AND o.orderDate = '$orderTime'
");

if (mysqli_num_rows($query) == 0) {
    die("No matching orders found.");
}

$total = 0;
$deliveryCharge = 0;

$rowSample = mysqli_fetch_assoc($query);
mysqli_data_seek($query, 0); // rewind

?>
<!DOCTYPE html>
<html>
<head>
    <title>Invoice</title>
    <style>
        body { font-family: Arial, sans-serif; padding: 20px; }
        table { width: 100%; border-collapse: collapse; margin-top: 20px; }
        th, td { border: 1px solid #ddd; padding: 8px; }
        th { background: #f2f2f2; }
    </style>
</head>
<body>

<h2>INVOICE</h2>
<p><strong>Customer:</strong> <?= $rowSample['name'] ?> (<?= $rowSample['email'] ?>)</p>
<p><strong>Address:</strong> <?= $rowSample['shippingAddress'] ?>, <?= $rowSample['shippingCity'] ?>, <?= $rowSample['shippingState'] ?> - <?= $rowSample['shippingPincode'] ?></p>
<p><strong>Order Time:</strong> <?= date("d-m-Y H:i:s", strtotime($rowSample['orderDate'])) ?></p>
<p><strong>Payment Method:</strong> <?= $rowSample['paymentMethod'] ?></p>

<table>
    <tr>
        <th>Product</th>
        <th>Company</th>
        <th>Price</th>
        <th>Qty</th>
        <th>Total</th>
    </tr>
    <?php while ($row = mysqli_fetch_assoc($query)): 
        $lineTotal = $row['productPrice'] * $row['quantity'];
        $total += $lineTotal;
        $deliveryCharge = max($deliveryCharge, $row['deliveryCharge']); // use the max of all
    ?>
    <tr>
        <td><?= $row['productName'] ?></td>
        <td><?= $row['productCompany'] ?></td>
        <td>₹<?= $row['productPrice'] ?></td>
        <td><?= $row['quantity'] ?></td>
        <td>₹<?= $lineTotal ?></td>
    </tr>
    <?php endwhile; ?>
    <tr>
        <td colspan="4" style="text-align:right;"><strong>Subtotal</strong></td>
        <td>₹<?= $total ?></td>
    </tr>
    <tr>
        <td colspan="4" style="text-align:right;"><strong>Delivery Charge</strong></td>
        <td>₹<?= $deliveryCharge ?></td>
    </tr>
    <tr>
        <td colspan="4" style="text-align:right;"><strong>Grand Total</strong></td>
        <td>₹<?= ($total + $deliveryCharge) ?></td>
    </tr>
</table>

</body>
</html>
